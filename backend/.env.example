# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dander

# Authentication
JWT_SECRET=your_jwt_secret_here
ADMIN_SECRET_KEY=your_admin_secret_key_here

# Email (Resend — leave blank in dev; OTP codes will print to console instead)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=noreply@yourdomain.com

# Twilio (SMS — leave blank in dev to skip SMS without errors)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+10000000000

# Cloudinary (media uploads)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Server
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Platform
PLATFORM_NAME=Dander
