# ── Dander User App — Environment Variables ──────────────────
# Copy this file to .env.local for local development.
# For production (Netlify), set these in Site → Environment variables.

# Backend API base URL.
# Local dev: leave empty — Vite proxy sends /api → localhost:4000
# Production: set to your Railway backend URL (no trailing slash)
VITE_API_URL=https://your-backend.up.railway.app

# Business portal URL (shown on the "For businesses" explainer CTA)
# Local dev: http://localhost:3001
# Production: set to your deployed business portal URL
VITE_BUSINESS_PORTAL_URL=https://business.yourdomain.com
